{
  "name": "@apicity/fal",
  "version": "0.1.0",
  "description": "Fal Platform API provider for model management, pricing, usage, and analytics.",
  "license": "MIT",
  "repository": "github:justintanner/apicity",
  "type": "module",
  "main": "dist/src/index.js",
