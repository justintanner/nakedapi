{
  "name": "@apicity/kimicoding",
  "version": "0.1.0",
  "description": "Kimi for Coding provider for Apicity - completely standalone with Anthropic Messages API format, streaming-first, and built-in middleware.",
  "license": "MIT",
  "repository": "github:justintanner/apicity",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./zod": {
      "import": "./dist/src/zod.js",
      "types": "./dist/src/zod.d.ts"
    }
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "ai",
    "kimi",
    "kimicoding",
    "k2p5",
    "anthropic",
    "chat",
    "streaming",
    "apicity"
  ],
  "author": "Justin Tanner",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/dist.mjs",
    "prepublishOnly": "pnpm run build"
  }
}
