{
  "name": "@apicity/anthropic",
  "version": "0.1.0",
  "description": "Anthropic / Claude provider for messages, batches, models, files, and admin APIs.",
  "license": "MIT",
  "repository": "github:justintanner/apicity",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "ai",
    "anthropic",
    "claude",
    "messages",
    "apicity"
  ],
  "author": "Justin Tanner",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/dist.mjs",
    "prepublishOnly": "pnpm run build"
  }
}
