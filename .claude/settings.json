{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path'); [[ (\"$f\" == *.ts || \"$f\" == *.tsx) && \"$f\" != *\".claude/\"* ]] && npx prettier --write \"$f\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
